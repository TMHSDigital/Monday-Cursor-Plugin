# Normalize all text files to LF in the repo; auto-detect binaries.
* text=auto eol=lf

# Explicit overrides for scripts/configs that must stay LF on checkout.
*.sh       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.md       text eol=lf

# Windows-only files keep CRLF.
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Common binaries - never touch.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.woff     binary
*.woff2    binary
